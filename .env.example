# ============================================================
# Auto-Project Docker 环境变量配置
# 复制此文件为 .env 并根据需要修改
#   cp .env.example .env
# ============================================================

# ---- 应用端口 ----
APP_PORT=8080
# JVM 参数
JAVA_OPTS=-Xms256m -Xmx512m

# ---- MySQL ----
MYSQL_ROOT_PASSWORD=root123
MYSQL_DATABASE=auto_project
MYSQL_PORT=3306

# ---- Redis ----
REDIS_PASSWORD=redis123
REDIS_PORT=6379
